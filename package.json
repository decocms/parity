{
  "name": "@decocms/parity",
  "version": "0.0.0",
  "description": "E2E parity validator for Fresh -> TanStack site migrations. CLI that compares two URLs and reports UI / functional / Web Vitals deltas.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/decocms/parity.git"
  },
  "homepage": "https://github.com/decocms/parity#readme",
  "bugs": {
    "url": "https://github.com/decocms/parity/issues"
  },
  "keywords": [
    "deco",
    "tanstack",
    "fresh",
    "migration",
    "e2e",
    "playwright",
    "web-vitals",
    "visual-regression"
  ],
  "bin": {
    "parity": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run --hot src/cli.ts",
    "build": "bun build src/cli.ts --target=node --outfile=dist/cli.js --packages=external && bun run scripts/postbuild.ts",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint .",
    "fmt": "biome format --write ."
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "open": "^10.1.0",
    "ora": "^8.1.1",
    "pixelmatch": "^6.0.0",
    "playwright": "^1.49.0",
    "pngjs": "^7.0.0",
    "web-vitals": "^4.2.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ]
}
